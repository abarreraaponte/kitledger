{
	"compilerOptions": {
		"lib": ["ES2022", "DOM", "DOM.Iterable", "deno.ns", "deno.unstable", "deno.worker"],
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"jsxImportSourceTypes": "@types/react"
	},
	"fmt": {
		"useTabs": true,
		"lineWidth": 120,
		"indentWidth": 4,
		"semiColons": true,
		"singleQuote": false,
		"include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.json"],
		"nextControlFlowPosition": "nextLine"
	},
	"imports": {
		"@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.6",
		"@faker-js/faker": "npm:@faker-js/faker@^9.9.0",
		"@hono/hono": "jsr:@hono/hono@^4.8.4",
		"@node-rs/argon2": "npm:@node-rs/argon2@^2.0.2",
		"@poolifier/poolifier-web-worker": "jsr:@poolifier/poolifier-web-worker@^0.5.8",
		"@server/": "./server/",
		"@client": "./client",
		"@std/assert": "jsr:@std/assert@1",
		"@std/path": "jsr:@std/path@^1.1.1",
		"@std/testing": "jsr:@std/testing@^1.0.15",
		"@std/uuid": "jsr:@std/uuid@^1.0.9",
		"@vitejs/plugin-vue": "npm:@vitejs/plugin-vue@^6.0.4",
		"drizzle-kit": "npm:drizzle-kit@^0.31.4",
		"drizzle-orm": "npm:drizzle-orm@^0.44.2",
		"knex": "npm:knex@^3.1.0",
		"pg": "npm:pg@^8.16.3",
		"postgres": "npm:postgres@^3.4.7",
		"valibot": "npm:valibot@^1.2.0",
		"vite": "npm:vite@^7.3.1",
		"vue": "npm:vue@^3.5.29"
	},
	"nodeModulesDir": "auto",
	"tasks": {
		"build": "deno run -A npm:vite build",
		"db:custom": "deno run -A npm:drizzle-kit generate --custom",
		"db:generate": "deno run -A npm:drizzle-kit generate",
		"dev": "deno run -A --watch --env-file --unstable-worker-options ./server/main.ts & deno run -A npm:vite",
		"format": "deno fmt",
		"setup": "deno run -A --watch --env-file --unstable-worker-options ./server/main.ts setup",
		"test": "deno test --unstable-worker-options --env-file -A",
		"typecheck": "deno check server/**/*.ts test/**/*.ts client/**/*.tsx client/**/*.ts"
	}
}
